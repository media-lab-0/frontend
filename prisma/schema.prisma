
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tag {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  slug            String        @unique
  type            String        @default("tag")
  is_category     Boolean       @default(false)
  is_popular      Boolean       @default(false)
  image_url       String?
  last_scraped_at DateTime?     @db.Timestamptz(6)
  galleries       GalleryTag[]

  @@map("tags")
}

model Gallery {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title           String
  slug            String        @unique
  url             String
  cover_url       String?
  views           Int           @default(0)
  rating          Float         @default(0)
  last_scraped_at DateTime?     @db.Timestamptz(6)
  images          Image[]
  tags            GalleryTag[]

  @@map("galleries")
}

model Image {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gallery_id String   @db.Uuid
  url        String
  created_at DateTime @default(now()) @db.Timestamptz(6)
  gallery    Gallery  @relation(fields: [gallery_id], references: [id], onDelete: Cascade)

  @@unique([gallery_id, url])
  @@map("images")
}

model GalleryTag {
  gallery_id String  @db.Uuid
  tag_id     String  @db.Uuid
  gallery    Gallery @relation(fields: [gallery_id], references: [id], onDelete: Cascade)
  tag        Tag     @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@id([gallery_id, tag_id])
  @@map("gallery_tags")
}
